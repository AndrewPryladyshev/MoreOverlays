<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".appearance_settings.AppearanceFragment"

    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/preview"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        app:layout_constraintTop_toTopOf="parent"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preview"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:layout_marginBottom="8dp"
            />


        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            style="?attr/materialCardViewFilledStyle"
            app:cardCornerRadius="24dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/previewPager"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginBottom="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/toggleSideSelector"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleSideSelector"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:checkedButton="@+id/btnRight"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <Button
                        android:id="@+id/btnLeft"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Left"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />

                    <Button
                        android:id="@+id/btnBoth"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Both"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />

                    <Button
                        android:id="@+id/btnRight"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Right"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

                <!--                <TextView-->
                <!--                    android:layout_width="wrap_content"-->
                <!--                    android:layout_height="wrap_content"-->
                <!--                    android:text="Side"-->
                <!--                    android:textAppearance="?attr/textAppearanceBodySmall"-->
                <!--                    app:layout_constraintBottom_toBottomOf="parent"-->
                <!--                    app:layout_constraintStart_toStartOf="parent"-->
                <!--                    app:layout_constraintEnd_toEndOf="parent"-->
                <!--                    android:layout_marginTop="50dp"-->
                <!--                    />-->

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>



        <!--        <com.google.android.material.card.MaterialCardView-->
        <!--            android:id="@+id/left_detector"-->
        <!--            android:layout_width="15dp"-->
        <!--            android:layout_height="150dp"-->
        <!--            android:background="@color/grey"-->
        <!--            android:clickable="false"-->
        <!--            android:layout_gravity="start"/>-->

        <!--        <com.google.android.material.card.MaterialCardView-->
        <!--            android:id="@+id/right_detector"-->
        <!--            android:layout_width="15dp"-->
        <!--            android:layout_height="150dp"-->
        <!--            android:background="@color/grey"-->
        <!--            android:clickable="false"-->
        <!--            android:layout_gravity="end"/>-->

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/preview"
        app:layout_constraintBottom_toBottomOf="parent"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gesture Detectors"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:layout_marginBottom="8dp"
                />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                style="?attr/materialCardViewFilledStyle"
                app:cardCornerRadius="16dp"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Corner Radius"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderCornerRadius"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="16"
                        android:value="8"
                        android:stepSize="1"
                        app:tickVisible="true"
                        app:labelBehavior="floating"
                        app:trackHeight="4dp"
                        app:thumbRadius="2dp"
                        app:thumbHeight="15dp"/>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="12dp"
                        app:dividerColor="?attr/colorOutlineVariant" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Width"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderWidth"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="1"
                        android:valueTo="100"
                        android:value="16"
                        android:stepSize="1"
                        app:tickVisible="true"
                        app:labelBehavior="floating"
                        app:trackHeight="4dp"
                        app:thumbRadius="2dp"
                        app:thumbHeight="15dp"/>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="12dp"
                        app:dividerColor="?attr/colorOutlineVariant" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Background Opacity"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderOpacity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="1"
                        android:value="0.5"
                        android:stepSize="0.1"
                        app:tickVisible="true"
                        app:labelBehavior="floating"
                        app:trackHeight="4dp"
                        app:thumbRadius="2dp"
                        app:thumbHeight="15dp"/>



                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Enable Blur Effect"
                            android:textAppearance="?attr/textAppearanceBodyLarge" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="12dp"
                        app:dividerColor="?attr/colorOutlineVariant" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Advanced Settings"
                            android:textAppearance="?attr/textAppearanceBodyLarge" />

                        <!--                        <com.google.android.material.materialswitch.MaterialSwitch-->
                        <!--                            android:id="@+id/is_detectors_position_changing_enabled"-->
                        <!--                            android:layout_width="wrap_content"-->
                        <!--                            android:layout_height="wrap_content" />-->

                        <ImageButton
                            android:id="@+id/advanced"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_arrow_right"
                            android:scaleX="0.2"
                            android:scaleY="0.2"/>

                    </LinearLayout>

                </LinearLayout>



            </com.google.android.material.card.MaterialCardView>


            <!--        <com.google.android.material.card.MaterialCardView-->
            <!--            android:layout_width="match_parent"-->
            <!--            android:layout_height="wrap_content"-->

            <!--            style="?attr/materialCardViewFilledStyle"-->
            <!--            app:cardCornerRadius="16dp">-->

            <!--        </com.google.android.material.card.MaterialCardView>-->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Overlays"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="24dp"
                />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                style="?attr/materialCardViewFilledStyle"
                app:cardCornerRadius="16dp"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Corner Radius"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderOverlaysCornerRadius"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="32"
                        android:value="16"
                        android:stepSize="1"
                        app:tickVisible="true"
                        app:labelBehavior="floating"
                        app:trackHeight="4dp"
                        app:thumbRadius="2dp"
                        app:thumbHeight="15dp"/>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="12dp"
                        app:dividerColor="?attr/colorOutlineVariant" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Width"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderOverlaysWidth"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="24"
                        android:value="16"
                        android:stepSize="1"
                        app:tickVisible="true"
                        app:labelBehavior="floating"
                        app:trackHeight="4dp"
                        app:thumbRadius="2dp"
                        app:thumbHeight="15dp"/>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="12dp"
                        app:dividerColor="?attr/colorOutlineVariant" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rows"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderOverlaysAppsInRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="24"
                        android:value="16"
                        android:stepSize="1"
                        app:tickVisible="true"
                        app:labelBehavior="floating"
                        app:trackHeight="4dp"
                        app:thumbRadius="2dp"
                        app:thumbHeight="15dp"/>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="12dp"
                        app:dividerColor="?attr/colorOutlineVariant" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Background Opacity"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderOverlaysOpacity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="1"
                        android:value="0.5"
                        android:stepSize="0.1"
                        app:tickVisible="true"
                        app:labelBehavior="floating"
                        app:trackHeight="4dp"
                        app:thumbRadius="2dp"
                        app:thumbHeight="15dp"/>



                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Enable Blur Effect"
                            android:textAppearance="?attr/textAppearanceBodyLarge" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="12dp"
                        app:dividerColor="?attr/colorOutlineVariant" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Enable Posion Changing"
                            android:textAppearance="?attr/textAppearanceBodyLarge" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/is_overlays_position_changing_enabled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                </LinearLayout>



            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                style="?attr/materialCardViewFilledStyle"
                app:cardCornerRadius="16dp">

            </com.google.android.material.card.MaterialCardView>


            <!--            <TextView-->
            <!--                android:layout_width="match_parent"-->
            <!--                android:layout_height="wrap_content"-->
            <!--                android:text="Swipe the edges to preview changes instantly."-->
            <!--                android:textAlignment="center"-->
            <!--                android:layout_marginTop="16dp"-->
            <!--                android:textAppearance="?attr/textAppearanceBodyMedium"-->
            <!--                android:alpha="0.7"-->
            <!--                />-->

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>



</androidx.constraintlayout.widget.ConstraintLayout>