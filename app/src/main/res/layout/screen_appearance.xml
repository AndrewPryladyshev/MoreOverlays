<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        style="?attr/materialCardViewFilledStyle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Panel Style"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Background Opacity (90%)"
                android:textAppearance="?attr/textAppearanceBodyMedium" />
            <com.google.android.material.slider.Slider
                android:id="@+id/slider_opacity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="100"
                android:value="90" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Background Blur (50%)"
                android:textAppearance="?attr/textAppearanceBodyMedium" />
            <com.google.android.material.slider.Slider
                android:id="@+id/slider_blur"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="100"
                android:value="50" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Corner Radius (70%)"
                android:textAppearance="?attr/textAppearanceBodyMedium" />
            <com.google.android.material.slider.Slider
                android:id="@+id/slider_radius"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="100"
                android:value="70" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Panel Width (40%)"
                android:textAppearance="?attr/textAppearanceBodyMedium" />
            <com.google.android.material.slider.Slider
                android:id="@+id/slider_width"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="100"
                android:value="40" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>