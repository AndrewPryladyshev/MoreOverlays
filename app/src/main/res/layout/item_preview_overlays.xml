<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_pager_container"
    >

    <com.google.android.material.divider.MaterialDivider
        android:id="@+id/materialDivider1"
        android:layout_width="1dp"
        android:layout_height="0dp"
        app:dividerColor="?attr/colorOutline"
        app:dividerThickness="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="40dp"/>

    <com.google.android.material.divider.MaterialDivider
        android:id="@+id/materialDivider2"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:layout_marginStart="40dp"
        app:dividerColor="?attr/colorOutline"
        app:dividerThickness="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="1dp"
        android:layout_height="0dp"
        app:dividerColor="?attr/colorOutline"
        app:dividerThickness="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>


    <GridLayout
        android:id="@+id/previewRight"
        android:layout_width="30dp"
        android:layout_height="140dp"
        android:background="@drawable/right_side_overlay_bg"
        android:alpha="0.5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/materialDivider1"
        app:layout_constraintTop_toTopOf="parent">

    </GridLayout>

    <GridLayout
        android:id="@+id/previewLeft"
        android:layout_width="30dp"
        android:layout_height="140dp"
        android:background="@drawable/left_side_overlay_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/materialDivider2"
        app:layout_constraintTop_toTopOf="parent"
        android:alpha="0.5">

    </GridLayout>

